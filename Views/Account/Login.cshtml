@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h2 class="text-white mb-4">Login</h2>
            <form method="post">
                <div class="mb-3">
                    <label class="text-white" style="color: #6ef06e;">Username</label>
                    <input name="username" type="text" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="text-white" style="color: #e8c840;">Password</label>
                    <input name="password" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn btn-ffx w-100">Login</button>
            </form>
        </div>
    </div>
</div>